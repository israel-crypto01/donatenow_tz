{
    "name": "donatenow/tanzania",
    "description": "DONATE NOW Tanzania — PHP charitable giving platform",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "phpmailer/phpmailer": "^6.8",
        "google/apiclient": "^2.15"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "DonateNow\\": "backend/src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "google/apiclient-services": true
        }
    },
    "scripts": {
        "test": "phpunit tests/"
    }
}
